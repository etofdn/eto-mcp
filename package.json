{
  "name": "@eto/mcp",
  "version": "0.1.0",
  "description": "ETO MCP gateway — operational issuer services that bridge external identity systems (Worldcoin, Civic, etc.) and skill attestations into ETO's IssueCredential flow.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./issuers/worldcoin": {
      "types": "./dist/issuers/worldcoin.d.ts",
      "import": "./dist/issuers/worldcoin.js"
    },
    "./issuers/civic": {
      "types": "./dist/issuers/civic.d.ts",
      "import": "./dist/issuers/civic.js"
    },
    "./issuers/kyc-test": {
      "types": "./dist/issuers/kyc-test.d.ts",
      "import": "./dist/issuers/kyc-test.js"
    },
    "./issuers/skill-cert": {
      "types": "./dist/issuers/skill-cert.d.ts",
      "import": "./dist/issuers/skill-cert.js"
    },
    "./issuers/bank-mock": {
      "types": "./dist/issuers/bank-mock.d.ts",
      "import": "./dist/issuers/bank-mock.js"
    },
    "./issuers/bank": {
      "types": "./dist/issuers/bank.d.ts",
      "import": "./dist/issuers/bank.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.issuers.json && tsc -p tsconfig.build.services.json",
    "typecheck": "tsc -p tsconfig.issuers.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.issuers.json"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.0",
    "bs58": "^6.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@noble/curves": "^1.4.0",
    "pg": "^8.13.0",
    "@noble/ed25519": "^2.0.0",
    "@noble/hashes": "^1.4.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "express": "^5.2.1",
    "zod": "^3.25.76"
  }
}
